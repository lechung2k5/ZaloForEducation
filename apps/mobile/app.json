{
  "expo": {
    "name": "Zalo Education",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_white.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_white.png",
      "resizeMode": "contain",
      "backgroundColor": "#00418f"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_white.png",
        "backgroundColor": "#00418f"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo_white.png"
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication"
    ]
  }
}
