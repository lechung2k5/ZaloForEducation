{
  "name": "zalo-edu-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev -w backend",
    "web:dev": "npm run dev -w apps/web",
    "mobile:dev": "npm run start -w apps/mobile",
    "install:all": "npm install"
  },
  "dependencies": {
    "@nestjs/mongoose": "^11.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongoose": "^9.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
